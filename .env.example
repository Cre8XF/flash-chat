# Firebase — get these from the Firebase console → Project settings → Your apps
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# FCM — Web Push certificate key from Firebase console → Project settings → Cloud Messaging → Web Push certificates
VITE_FIREBASE_VAPID_KEY=your_vapid_key

# Cloudflare R2 — URL of your deployed upload-worker (worker/upload-worker.js)
# Leave empty to fall back to Firebase Storage
VITE_R2_WORKER_URL=https://flash-upload.your-subdomain.workers.dev
